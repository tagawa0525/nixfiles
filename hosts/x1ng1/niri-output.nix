# =============================================================================
# x1ng1 (ThinkPad X1 Nano 1st Gen) のNiriディスプレイ設定
# =============================================================================
# Niriウィンドウマネージャ用のディスプレイ設定。
# この設定はHome Managerを通じて modules/home/niri.nix に渡されます。
#
# 設定の確認方法:
#   niri msg outputs  # 接続中のディスプレイ一覧を表示
#
# 設定例:
#   output "eDP-1" {        # ディスプレイ名
#       mode "2160x1350@60" # 解像度@リフレッシュレート
#       scale 1.5           # スケーリング（HiDPI用）
#       position x=0 y=0    # マルチモニタ時の位置
#   }
# =============================================================================
{
  niriOutputConfig = ''
    // x1ng1ノートPCのディスプレイ設定
    // ThinkPad X1 Nano Gen 1: 13インチ WUXGA (2160x1350, 16:10)
    // HiDPI設定: 1.5x スケーリングで読みやすさとスペースのバランスを取る
    output "eDP-1" {
        mode "2160x1350@60"
        scale 1.25
        transform "normal"
        position x=0 y=0
    }
  '';
}
