# =============================================================================
# Server プロファイル
# =============================================================================
# headless（GUI なし）で常時稼働するホスト共通の設定。
# SSH・Tailscale・ファイアウォール・Podman 等の基盤は base.nix が提供する。
# workstation.nix は import しないこと（DE・フォント・GUI アプリが入るため）。
# 各 server ホストは hosts/<name>/default.nix から本ファイルを import する。
#
# リモートビルドを受け付ける場合は、ホスト側で
# ../nix-distributed-builds/builder.nix を追加で import する。
# =============================================================================
{
  # ===========================================================================
  # 電源管理
  # ===========================================================================
  # 常時稼働のため、サスペンド・ハイバネート系の target を無効化する
  systemd.targets = {
    sleep.enable = false;
    suspend.enable = false;
    hibernate.enable = false;
    hybrid-sleep.enable = false;
  };
}
