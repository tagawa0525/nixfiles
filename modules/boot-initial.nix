# =============================================================================
# 初期セットアップ用ブート設定 (Non Secure Boot)
# =============================================================================
# systemd-boot をブートローダとして使う、Secure Boot 無効状態の設定。
# 新規ホストの初期セットアップや、Secure Boot を必要としない構成で使用する。
# Secure Boot を有効化する場合は modules/boot-lanzaboote.nix を参照。
# 各ホストでimportして使用。
# =============================================================================
{ pkgs, ... }:

{
  # ===========================================================================
  # ブートローダー設定
  # ===========================================================================
  # Non Secure Boot
  boot.loader.systemd-boot.enable = true;
  boot.loader.efi.canTouchEfiVariables = true;

  # ===========================================================================
  # カーネル設定
  # ===========================================================================
  # 最新のLinuxカーネルを使用（新しいハードウェアサポートのため）
  boot.kernelPackages = pkgs.linuxPackages_latest;

  # ===========================================================================
  # ハイバネート設定
  # ===========================================================================
  # 休止状態からの復帰用スワップデバイス
  boot.resumeDevice = "/dev/disk/by-label/swap";
}
